#!/bin/sh
# Helper functions {{{1
# NOTE: these are unset at the end of the file
#
# have {{{2
#
# @description Check PATH for a command
#
# @arg $1 str Command to search for
#
# @exitcode true if found
# @exitcode false if not found
#
have() { command -v "$1" >/dev/null; }

# Defaults {{{1
#
# These will be modified if grc(1) is available

jobs='jobs -l' # list PIDs
alias jobs="$jobs"

# grep removes loopback
# sed removes IPv6 addresses
ipa='ip --color=always --brief address \
    | grep -v "\blo\b" \
    | sed "s@[0-9a-f]*:[0-9a-f]*.[0-9]*@@g; s/[[:space:]]*$//"'
alias ipa="$ipa"

# Add a blank line after uptime
# Truncate at $COLUMNS (roughly because of color escapes)
w='w | sed 1G | colrm $COLUMNS'
alias w="$w"

# grc(1)-only aliases {{{1
# Put these first so that they can be overriden
#
if have grc; then
    export GRC_OPTS='-es' # colorize stderr and stdout
    # grc must be defined because later aliases use grc(1) only if this variable
    # is defined
    # shellcheck disable=SC2016
    grc='grc $GRC_OPTS'
    alias grc="$grc"

    # Create alias for all configs found *if* the command exists
    for c in /usr/share/grc/conf.* ~/.grc/conf.*; do
        c=${c##*/}; c=${c#conf.} # extract command name
        have "$c" && alias "$c=grc $c"
    done

    # Other aliases
    alias configure='grc ./configure'
         alias make='grc make'
            alias w="grc --colour on $w"
          alias who='grc who'

    # Override /etc/grc.conf setting
    alias lastlog='grc --config conf.lastlog lastlog'

    # conf.go-test
    alias go='grc go'

    # conf.semanage{boolean,fcontext,user}
    alias semanage="grc semanage"
    alias getsebool="grc getsebool"

    # Force my grc config so running with sudo still works
    alias lastb='grc --config $HOME/.grc/conf.last lastb'

    # Line buffer stdout so it won't appear to hang
    # Force my grc config so running with sudo still works
    alias tcpdump="grc --config $HOME/.grc/conf.tcpdump tcpdump -l"

    # grc doesn't select the right config
    alias printenv='grc --config conf.printenv printenv'

    # jobs has to run in the current shell
    alias jobs="$jobs${BASH:+ | grcat conf.jobs}"

    # `dnf install|upgrade` does not work properly with grc
    unalias dnf

    # Force line buffering so ping doesn't appear to hang
    alias ping="grc --config conf.ping stdbuf -oL ping"

    # Force the config as the options given to ip prevent grc
    # from identifying it
    # Force color so it passes through the pipeline
    alias ipa="grc --config conf.ipaddr --colour on $ipa"

    # Clear defaults
    unset ipa jobs w
fi

# fzf aliases {{{1
#
if have fzf; then
    alias kill=fkill
fi

# ls(1) {{{1
#
# In case $LS was not defined in ~/.env
[ -z "$LS" ] && LS=ls

ls=$LS

# Use GNU options if available
[ "$ls" = ls ] && command ls --version 2>/dev/null | grep -q GNU && ls=gnu-ls

case $ls in
    eza | exa)
        ls_opts='';      ll_opts='-lg';
        la_opts='-a';    lla_opts='-lag';
        ld_opts='-d .*'; lld_opts='-lg -d .*';
        lspa_opts=''
        ;;
    gnu-ls) # GNU ls
        ls_opts='';      ll_opts='-l';
        la_opts='-A';    lla_opts='-lA';
        ld_opts='-d .*'; lld_opts='-l -d .*';
        lspa_opts='-A'
        ;;
    ls) # POSIX ls
        ls_opts='';      ll_opts='-l';
        la_opts='-a';    lla_opts='-la';
        ld_opts='-d .*'; lld_opts='-lg -d .*';
        lspa_opts='-A'
        ;;
    *) printf 'How did we get here?\n' >&2 ;;
esac

# Force color if using grc with an ls that supports color
unset grc_col
if have grc && [ -n "$HAS_COLOR" ] && [ "$ls" = 'gnu-ls' ]; then
    grc_col='--color=always'
fi

# Single-quote $LS_OPTS so it can be changed on the fly
# shellcheck disable=SC2153
alias   ls="$LS $ls_opts "'$LS_OPTS'
alias   ll="${grc:+grc }$LS $ll_opts "'$LS_OPTS'" $grc_col"
alias   ld="${grc:+grc }$LS $ll_opts -d "'$LS_OPTS'" $grc_col"
alias   la="$LS $la_opts "'$LS_OPTS'
alias  lla="${grc:+grc } $LS $lla_opts "'$LS_OPTS'" $grc_col"
alias   l.="$LS $ld_opts "'$LS_OPTS'
alias  ll.="${grc:+grc } $LS $lld_opts "'$LS_OPTS'" $grc_col"
alias lspa="lsp $lspa_opts" # lsp is defined in ~/.functions

unset ls ls_opts la_opts ll_opts lla_opts ld_opts lld_opts ldap_opts grc_col


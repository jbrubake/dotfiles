#!/bin/sh
#
# shellcheck disable=SC3043

# Prompt functions {{{1
if test -n "$BASH"; then
# prompt_detached: Determine number of detached screen/tmux sessions {{{2
#
# Arguments:
#   $1: string to append to output
#
# Output: number of detached sessions with $1 appended
#
prompt_detached () {
    if command -v screen >/dev/null; then
        local n_screen=$(screen -ls 2> /dev/null | grep -c '[Dd]etach[^)]*)$')
    fi
    if command -v tmux >/dev/null; then
        local n_tmux=$(tmux list-sessions 2> /dev/null | grep -cv attached)
    fi

    local detached=$(( n_screen + n_tmux ))

    [ "$detached" -ne 0 ] && printf '%s%s' "$detached" "$1"
}
# prompt_running: Get running jobs {{{2
#
# (Only works under Bash)
#
# Arguments:
#   $1: string to append to output
#
# Output: number of background jobs with $1 appended
#
prompt_running() {
    j="$( \jobs -r | wc -l | tr -d " " )"
    [ "$j" -ne 0 ] && printf '%s%s' "$j" "$1"
}

# prompt_stopped: Get stopped jobs {{{2
#
# (Only works under Bash)
#
# Arguments:
#   $1: string to append to output
#
# Output: number of stopped jobs with $1 appended
#
prompt_stopped() {
    j="$( \jobs -s | wc -l | tr -d " " )"
    [ "$j" -ne 0 ] && printf '%s%s' "$j" "$1"
}

# prompt_combine: Combine strings {{{2
#
# If the resulting string is empty then nothing is printed
#
# Arguments:
#   $1: beginning string
#   $2: ending string
#   $3: item separator
#   ...: strings to join
#
# Example:
#   $ prompt_combine '<' '>' '|' foo bar baz
#   <foo|bar|baz>
#
prompt_combine() {
    fmt=$1; shift
    sep=$1; shift

    [ $# -eq 0 ] && return

    s=$1; shift
    for a in "$@"; do
        [ -z "$a" ] && continue
        s=$s$sep$a
    done
    printf %s "$fmt" | sed "s/%s/$s/"
}

# prompt_load: Get system load {{{2
prompt_load () {
    local one=
    local five=
    local rest=
    read -r one five rest < /proc/loadavg
    printf "%s:%s" "$one" "$five"
}

# prompt_uptime: Get uptime {{{2
prompt_uptime () {
    local uptime=$(cat /proc/uptime)
    uptime=${uptime%%.*}

    local mins=$(( uptime/60%60 ))
    local hours=$(( uptime/60/60%24 ))
    local days=$(( uptime/60/60/24 ))

    if [ "$days" -ne "0" ]
    then
        printf "%sd " "${days}"
    fi
    printf "%s:%s" "${hours}" "${mins}"
}

# is_ssh: Determine if running under ssh {{{2
#
# Returns:
#   true if running over SSH
#   false otherwise
#
is_ssh () { [ -n "$SSH_CLIENT$SSH2_CLIENT$SSH_TTY" ]; }

# prompt_tty: Get tty {{{2
prompt_tty () {
    tty | sed -e 's:/dev/::'
}

# prompt_pwd: Print pwd with colors {{{2
#
# prompt_pwd modified from Yu-Jie Lin's example <libb.wordpress.com>
#
# Arguments:
#   $1 : directory color
#   $2 : slash color
prompt_pwd () {
    local dir_clr="$1"
    local slash_clr="$2"
    local pwd="$PWD"
    pwd="${pwd/#$HOME/\~}"
    echo "$dir_clr${pwd//\//$slash_clr\/$dir_clr}"
}

# prompt_error: Print exit value of last command if it is non-zero {{{2
#
# prompt_error modified from Yu-Jie Lin's example <libb.wordpress.com>
#
# Arguments:
#   $1: output color
prompt_error () {
    local error_clr="$1"

    if [ "$RETVAL" -gt 0 ]; then (( i = 3 - ${#RETVAL} ));
        printf "%s[" "$error_clr";
        [ "$i" -gt 0 ] && printf "%s" " ";
        printf "%s" "$RETVAL";
        [ "$i" -eq 2 ] && printf "%s" " ";
        printf "]" ;
    fi
}

# prompt_git: Print current git branch and the following status codes: {{{2
#
# Arguments:
#   $1: Format string. %b is replaced with the branch name. %f is replaced with
#       the status flags. If $1 == -h or --help, the status flag meanings are
#       printed
#
# Example:
#   # In a repo with uncommitted changes and stashed files:
#   $ prompt_git '(%b: %s)'
#   (branch: +$)
#
prompt_git() {
    case $1 in
        '-h' | '--help')
            cat <<END
Flags:
+ : Uncommitted changes
! : Unstaged changes
? : Untracked files
$ : Stashed files
END
            return
            ;;
    esac

	# Abort if current directory is in not a git repository
	git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return

	# Get current branch
    #
    # Get the short symbolic ref. If HEAD is not a symbolic ref, get a tracking
    # remote branch or tag. Otherwise, get the short SHA for the latest commit,
    # or give up
	local branch=$(git symbolic-ref --quiet --short HEAD 2> /dev/null || \
		git describe --all --exact-match HEAD 2> /dev/null || \
		git rev-parse --short HEAD 2> /dev/null || \
		printf '%s' '(unknown)')

    # Set flags
	local s

    # Uncommitted changes
    ! git diff --quiet --ignore-submodules --cached      && s=$s+
    # Unstaged changes
    ! git diff-files --quiet --ignore-submodules --      && s=$s!
    # Untracked files
    [ -n "$(git ls-files --others --exclude-standard)" ] && s=$s?
    # Stashed files
    git rev-parse --verify refs/stash >/dev/null 2>&1    && s=$s$

    printf '%s' "$1" | sed -e "s/%b/$branch/" -e "s/%f/$s/"
}

fi # End bash-specific section
# Prompt color definitions {{{1
#

# Set prompt colors (these functions return nothing if color is not available)
#
dir_clr="\[$(FX reset; FG 2)\]"
slash_clr="\[$(FX reset; FG 1)\]"
git_branch_clr="\[$(FX reset; FG 3)\]"
git_status_clr="\[$(FX reset; FG 196)\]"
user_clr="\[$(FX reset; FG 6)\]"
root_user_clr="\[$(FX reset; FG 9)\]"
at_clr="\[$(FX reset; FG 12)\]"
hostname_clr="\[$(FX reset; FG 13)\]"
ssh_clr="\[$(FX reset; FX italic; FG 169)\]"
jobs_clr="\[$(FX reset; FG 8)\]"
history_clr="\[$(FX reset; FG 2)\]"
error_clr="\[$(FX reset; FG 7; BG 1)\]"
prompt_clr="\[$(FX reset; FG 11)\]"
bracket_clr="\[$(FX reset; FG 27)\]"
reset="\[$(FX reset)\]"

# Colorize username differently if we are root
test "$UID" = "0" && user_clr=$root_user_clr

# Strip the non-printing escapes if not running in bash {{{
if test -z "$BASH"; then 
    dir_clr=${dir_clr#\\[}
    slash_clr=${slash_clr#\\[}
    git_branch_clr=${git_branch_clr#\\[}
    git_status_clr=${git_status_clr#\\[}
    user_clr=${user_clr#\\[}
    root_user_clr=${root_user_clr#\\[}
    at_clr=${at_clr#\\[}
    hostname_clr=${hostname_clr#\\[}
    ssh_clr=${ssh_clr#\\[}
    jobs_clr=${jobs_clr#\\[}
    history_clr=${history_clr#\\[}
    error_clr=${error_clr#\\[}
    prompt_clr=${prompt_clr#\\[}
    bracket_clr=${bracket_clr#\\[}
    reset=${reset#\\[}
    dir_clr=${dir_clr%\\]}
    slash_clr=${slash_clr%\\]}
    git_branch_clr=${git_branch_clr%\\]}
    git_status_clr=${git_status_clr%\\]}
    user_clr=${user_clr%\\]}
    root_user_clr=${root_user_clr%\\]}
    at_clr=${at_clr%\\]}
    hostname_clr=${hostname_clr%\\]}
    ssh_clr=${ssh_clr%\\]}
    jobs_clr=${jobs_clr%\\]}
    history_clr=${history_clr%\\]}
    error_clr=${error_clr%\\]}
    prompt_clr=${prompt_clr%\\]}
    bracket_clr=${bracket_clr%\\]}
    reset=${reset%\\]}
fi # }}}

# Prompts {{{1
# Bash prompt {{{2
if test -n "$BASH"; then
#############################################
# This prompt looks roughly like this:
#
# pwd
# user@host ssh (git branch git status) {background|suspended|detached} !history [$?]
# $_
#############################################

PS1="$reset"
PS1="$PS1\$(prompt_pwd '$dir_clr' '$slash_clr')"
PS1="$PS1\n"
PS1="$PS1$user_clr\u$at_clr@$hostname_clr\h "
PS1="$PS1$ssh_clr\$(prompt_ssh && echo 'ssh ')"
PS1="$PS1\$(prompt_git '$bracket_clr($git_branch_clr %b $git_status_clr%f$bracket_clr) ')"
PS1="$PS1\$(prompt_combine '$bracket_clr{$jobs_clr%s$bracket_clr} ' '|' \$(prompt_running '\&') \$(prompt_stopped 'z'))"
PS1="$PS1$bracket_clr!$history_clr\! "
PS1="$PS1\$(prompt_error '$error_clr')$reset"
PS1="$PS1\n"
PS1="$PS1$prompt_clr$ $reset"

# Need to save $? here so that ps1_error can occur anywhere in the prompt
# Otherwise, new_pwd will clobber the value of $? that we want
#
# history -a allows multiple shells to write to the same history file
#
PROMPT_COMMAND='RETVAL=$?; history -a'
# sh prompt {{{2
else # End bash / start sh
#############################################
# This prompt looks roughly like this:
#
# 'pwd
# username@hostname
# $ '
#############################################

PS1="$reset\
$dir_clr\$(pwd)
$bracket_clr$user_clr$(whoami)$at_clr@$hostname_clr$(hostname)$bracket_clr
$prompt_clr$ $reset"
# PS1="\$(pwd)
# <$(whoami)@$(hostname)>\$ "
fi # End sh-specific section
# }}}
# Clean up {{{1
unset dir_clr slash_clr hostname_clr at_clr bracket_clr
unset git_branch_clr git_status_clr
unset history_clr error_clr prompt_clr user_clr root_user_clr
unset ssh_clr jobs_clr
unset reset

